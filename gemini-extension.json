{
  "name": "oh-my-gemini",
  "version": "2.0.1",
  "description": "Hook-enforced multi-agent orchestration for Gemini CLI. Zero learning curve, maximum power.",
  "author": "richardcb",
  "repository": "https://github.com/richardcb/oh-my-gemini",
  "license": "MIT",
  "keywords": [
    "gemini-cli",
    "multi-agent",
    "orchestration",
    "conductor",
    "hooks",
    "ai-agents",
    "agentic-coding",
    "docs-first"
  ],
  "engines": {
    "gemini-cli": ">=0.30.0"
  },
  "commands": [
    "commands/omg"
  ],
  "agents": [
    ".gemini/agents"
  ],
  "skills": [
    "skills"
  ],
  "policies": [
    "policies"
  ],
  "hooks": {
    "SessionStart": [
      {
        "name": "omg-session-start",
        "type": "command",
        "command": "node ${extensionPath}/hooks/session-start.js",
        "timeout": 5000,
        "description": "Load Conductor state and project context on startup"
      }
    ],
    "BeforeAgent": [
      {
        "name": "omg-context-injection",
        "type": "command",
        "command": "node ${extensionPath}/hooks/before-agent.js",
        "timeout": 10000,
        "description": "Dynamic context injection based on task type"
      }
    ],
    "BeforeTool": [
      {
        "name": "omg-security-gate",
        "type": "command",
        "command": "node ${extensionPath}/hooks/before-tool.js",
        "timeout": 15000,
        "description": "Security gates and git checkpoints before file/shell operations",
        "matcher": "write_file|replace|edit_file|create_file|run_shell_command|shell"
      }
    ],
    "AfterTool": [
      {
        "name": "omg-auto-verify",
        "type": "command",
        "command": "node ${extensionPath}/hooks/after-tool.js",
        "timeout": 60000,
        "description": "Auto-verification (typecheck, lint) after code changes",
        "matcher": "write_file|replace|edit_file|create_file"
      }
    ],
    "BeforeToolSelection": [
      {
        "name": "omg-tool-filter",
        "type": "command",
        "command": "node ${extensionPath}/hooks/tool-filter.js",
        "timeout": 5000,
        "description": "Filter tools based on detected agent mode (researcher/architect/executor)"
      }
    ],
    "AfterAgent": [
      {
        "name": "omg-phase-gate",
        "type": "command",
        "command": "node ${extensionPath}/hooks/phase-gate.js",
        "timeout": 10000,
        "description": "Conductor phase verification gates"
      },
      {
        "name": "omg-ralph-retry",
        "type": "command",
        "command": "node ${extensionPath}/hooks/ralph-retry.js",
        "timeout": 5000,
        "description": "Persistence mode (Ralph) - automatic retry on failure"
      }
    ]
  },
  "configuration": {
    "phaseGates.enabled": {
      "description": "Enable Conductor phase gate detection",
      "type": "boolean",
      "default": true
    },
    "phaseGates.strict": {
      "description": "If true, phase gates block progression until user confirms",
      "type": "boolean",
      "default": false
    },
    "autoVerification.enabled": {
      "description": "Run typecheck/lint after code changes",
      "type": "boolean",
      "default": true
    },
    "autoVerification.typecheck": {
      "description": "Run TypeScript type checking",
      "type": "boolean",
      "default": true
    },
    "autoVerification.lint": {
      "description": "Run linting",
      "type": "boolean",
      "default": true
    },
    "security.gitCheckpoints": {
      "description": "Create git checkpoints before file modifications",
      "type": "boolean",
      "default": true
    },
    "toolFilter.enabled": {
      "description": "Filter tools based on detected agent mode",
      "type": "boolean",
      "default": true
    },
    "ralph.enabled": {
      "description": "Enable persistence mode (ralph) for automatic retry",
      "type": "boolean",
      "default": true
    },
    "contextInjection.conductorState": {
      "description": "Inject active Conductor track info",
      "type": "boolean",
      "default": true
    }
  }
}
