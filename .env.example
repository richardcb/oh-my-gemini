# oh-my-gemini environment variables
# Copy this file to .env and fill in your values

# =============================================================================
# MCP Server Integrations (optional)
# =============================================================================
# These power the MCP servers defined in mcp/servers.json.
# Only needed if you want to use the corresponding MCP capabilities.

# GitHub MCP Server - repo access, PRs, issues
# Get a token at: https://github.com/settings/tokens (needs 'repo' scope)
# GITHUB_PAT=your-github-pat-here

# Exa - web search and code examples for AI agents
# Works without a key (free tier, rate limited)
# For higher limits, get a key at: https://dashboard.exa.ai/api-keys
# Then update mcp/servers.json httpUrl to: https://mcp.exa.ai/mcp?exaApiKey=YOUR_KEY
# EXA_API_KEY=your-exa-key-here

# Context7 - library documentation lookup
# Sign up at: https://context7.com
# CONTEXT7_API_KEY=your-context7-key-here

# =============================================================================
# Debugging (optional)
# =============================================================================
# Enable debug logging for oh-my-gemini hooks
# OMG_DEBUG=1
